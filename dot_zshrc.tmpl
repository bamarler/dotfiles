{{- if lookPath "hyprland" }}
# Auto-start Hyprland on TTY1
if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
  exec start-hyprland
fi
{{- end }}

# ===========================
# OH-MY-ZSH CONFIG
# ===========================
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
  git
  docker
  sudo
  copypath
  copyfile
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# ===========================
# PATH & ENVIRONMENT
# ===========================
{{- if eq .chezmoi.os "linux" }}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{- else if eq .chezmoi.os "darwin" }}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- end }}
eval "$(mise activate zsh)"
export PATH="$HOME/.local/bin:$PATH"
{{- if .use1Password }}
export SSH_AUTH_SOCK=~/.1password/agent.sock
{{- end }}

# fzf integration
source <(fzf --zsh)

# ===========================
# MODERN CLI TOOL ALIASES
# ===========================
# eza (better ls)
alias ls='eza --color=always --icons=always'
alias ll='eza -la --color=always --icons=always --git'
alias lt='eza --tree --level=2 --icons=always'
alias la='eza -a --color=always --icons=always'

# bat (better cat)
alias cat='bat --paging=never'
alias catp='bat'

# fd (better find)
alias find='fd'

# ripgrep (better grep)
alias grep='rg'

# zoxide (better cd)
alias cd='z'

# btop (better htop)
alias top='btop'
alias htop='btop'

# ===========================
# FZF + MODERN TOOLS INTEGRATION
# ===========================
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'

show_file_or_dir_preview="if [ -d {} ]; then eza --tree --color=always {} | head -200; else bat -n --color=always --line-range :500 {}; fi"
export FZF_CTRL_T_OPTS="--preview '$show_file_or_dir_preview'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always {} | head -200'"

# ===========================
# ALIASES: Package Managers
# ===========================
alias update-all='brew upgrade && flatpak update -y && sudo apt update && sudo apt upgrade -y'
alias b='bun'
alias bi='bun install'
alias br='bun run'
alias brd='bun run dev'
alias brb='bun run build'
alias brt='bun run test'
alias bx='bunx'

# ===========================
# ALIASES: Python (uv)
# ===========================
alias py='python3'
alias pip='uv pip'
alias pip3='uv pip'
alias uvinit='~/scripts/uv-init-pinned.sh'

# ===========================
# ALIASES: Git
# ===========================
alias g='git'
alias gs='git status'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit -m'
alias gp='git push'
alias gpl='git pull'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch'
alias gd='git diff'
alias gl='git log --graph --oneline --all --pretty=format:"%C(auto)%h %C(auto)%d %C(auto)%s %C(blue)(%cd %ae)" --date=format:"%I:%M %p %a %b %d"'
alias gpr='git fetch --prune && git branch -vv | grep :'
alias lg='lazygit'

# ===========================
# ALIASES: Docker
# ===========================
alias d='docker'
alias dc='docker compose'
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs -f'
alias dps='docker ps'
alias dpsa='docker ps -a'
alias dprune='docker system prune -af'

# ===========================
# CLAUDE CODE
# ===========================
alias cc='claude'
alias ccr='claude --resume'
alias ccc='claude --continue'
alias claude-init='~/scripts/init-claude-project.sh'
alias cidx="~/scripts/cidx.sh"

# ===========================
# MISE ALIASES
# ===========================
alias mr='mise run'
alias mu='mise use'
alias mi='mise install'
alias ml='mise list'
alias mx='mise exec'

# Quick language switching
alias usebun='mise use bun@latest'
alias usenode='mise use node@22'
alias usepy='mise use python@3.13'

# ===========================
# ALIASES: Navigation
# ===========================
alias ..='z ..'
alias ...='z ../..'
alias ....='z ../../..'
alias ~='z ~'

# ===========================
# ALIASES: Utilities
# ===========================
alias c='clear'
alias h='history'
alias hg='history | rg'
alias ports='netstat -tulanp'
alias myip='curl -s ifconfig.me'
alias weather='curl wttr.in'
alias sizeof='du -sh'
alias storage='ncdu'
alias wifi='~/scripts/rofi-wifi-menu/rofi-wifi-menu.sh'
alias about='neofetch'
alias reload-waybar='killall waybar && waybar &'
alias neu-vpn='sudo -E gpclient connect --browser default vpn.northeastern.edu'

# ===========================
# ALIASES: Quick Edits
# ===========================
alias zshrc='hx ~/.zshrc'
alias reload='source ~/.zshrc'

# ===========================
# FUNCTIONS
# ===========================
mkcd() { mkdir -p "$1" && z "$1"; }
fe() { fzf --preview 'bat --color=always {}' | xargs -r hx; }
se() { rg --line-number "$1" | fzf | cut -d: -f1 | xargs -r hx; }

# ===========================
# DOTS — dotfiles management
# ===========================
DOTS_SRC="${DOTS_SRC:-$(chezmoi source-path 2>/dev/null || echo "$HOME/.local/share/chezmoi")}"
DOTS_PACKAGES="$DOTS_SRC/packages"
DOTS_ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

dots() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    # ── Chezmoi passthrough ──
    apply)   chezmoi apply -v ;;
    diff)    chezmoi diff ;;
    status)  chezmoi status; echo ""; git -C "$DOTS_SRC" status --short ;;
    doctor)  chezmoi doctor ;;
    cd)      builtin cd "$DOTS_SRC" ;;
    edit)    chezmoi edit "$@" ;;

    # ── Sync & update ──
    sync)
      chezmoi re-add
      echo ""
      printf "\033[1mchezmoi status:\033[0m\n"
      chezmoi status 2>/dev/null || true
      echo ""
      printf "\033[1mgit status:\033[0m\n"
      git -C "$DOTS_SRC" status --short
      ;;
    update)
      git -C "$DOTS_SRC" pull --rebase
      chezmoi apply -v
      printf "\033[0;32m✓ Updated\033[0m\n"
      ;;

    # ── Install ──
    install)
      local target="${1:-all}"
      shift 2>/dev/null || true
      case "$target" in
        all)
          dots install omz
          dots install brew
          dots install apt
          dots install mise
          dots install cargo
          dots install uv
          dots install flatpak
          dots install vscode
          dots install fonts
          printf "\033[0;32m✓ All install targets complete\033[0m\n"
          ;;
        omz)
          echo "==> oh-my-zsh + plugins"
          if [ ! -d "$HOME/.oh-my-zsh" ]; then
            sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
          else
            echo "✓ oh-my-zsh already installed"
          fi
          [ ! -d "$DOTS_ZSH_CUSTOM/plugins/zsh-autosuggestions" ] && \
            git clone https://github.com/zsh-users/zsh-autosuggestions "$DOTS_ZSH_CUSTOM/plugins/zsh-autosuggestions"
          [ ! -d "$DOTS_ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ] && \
            git clone https://github.com/zsh-users/zsh-syntax-highlighting.git "$DOTS_ZSH_CUSTOM/plugins/zsh-syntax-highlighting"
          [ ! -d "$DOTS_ZSH_CUSTOM/themes/powerlevel10k" ] && \
            git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$DOTS_ZSH_CUSTOM/themes/powerlevel10k"
          ;;
        brew)
          echo "==> Homebrew packages"
          if ! command -v brew &>/dev/null; then
            echo "Installing Homebrew..."
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" </dev/null
            eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
          fi
          brew bundle --no-lock --file="$DOTS_PACKAGES/Brewfile"
          ;;
        apt)
          echo "==> System packages"
          source /etc/os-release
          case "$ID" in
            ubuntu|debian|linuxmint)
              sudo apt-get update -qq
              grep -v '^#' "$DOTS_PACKAGES/apt.txt" | grep -v '^$' | \
                xargs sudo apt-get install -y --no-install-recommends
              ;;
            arch|endeavouros|cachyos|manjaro)
              grep -v '^#' "$DOTS_PACKAGES/pacman.txt" | grep -v '^\[AUR\]' | grep -v '^$' | \
                xargs sudo pacman -S --needed --noconfirm
              ;;
            *) echo "Unsupported distro: $ID" ;;
          esac
          ;;
        mise)
          echo "==> mise runtimes"
          if command -v mise &>/dev/null; then mise install -y
          else echo "mise not found — brew install mise"; fi
          ;;
        cargo)
          echo "==> Cargo tools"
          if command -v cargo &>/dev/null; then cargo install hyprsession wallust 2>/dev/null || true
          else echo "cargo not found — install Rust first"; fi
          ;;
        uv)
          echo "==> uv tools"
          if command -v uv &>/dev/null; then
            for tool in codegraphcontext mcp-codebase-index pyright ruff; do
              uv tool install "$tool" 2>/dev/null || true
            done
          else echo "uv not found — brew install uv"; fi
          ;;
        flatpak)
          echo "==> Flatpak apps"
          if command -v flatpak &>/dev/null; then
            flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
            while IFS= read -r app; do
              [[ -z "$app" || "$app" == \#* ]] && continue
              flatpak install -y flathub "$app" 2>/dev/null || true
            done < "$DOTS_PACKAGES/flatpak.txt"
          else echo "flatpak not found"; fi
          ;;
        vscode)
          echo "==> VS Code extensions"
          if command -v code &>/dev/null; then
            while IFS= read -r ext; do
              [[ -z "$ext" ]] && continue
              code --install-extension "$ext" --force 2>/dev/null || true
            done < "$DOTS_PACKAGES/vscode-extensions.txt"
          else echo "VS Code not found"; fi
          ;;
        fonts)
          echo "==> FantasqueSansM Nerd Font"
          local font_dir="$HOME/.local/share/fonts/FantasqueSansM"
          if [ -d "$font_dir" ] && ls "$font_dir"/*.ttf &>/dev/null; then
            echo "✓ FantasqueSansM already installed"
          else
            mkdir -p "$font_dir"
            local tmp=$(mktemp -d)
            curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FantasqueSansM.zip" -o "$tmp/font.zip"
            unzip -qo "$tmp/font.zip" -d "$tmp/extracted"
            cp "$tmp"/extracted/FantasqueSansMNerdFontMono-*.ttf "$font_dir/"
            rm -rf "$tmp"
            fc-cache -f
            echo "✓ FantasqueSansM installed"
          fi
          ;;
        *) echo "Unknown install target: $target"; echo "Available: all omz brew apt mise cargo uv flatpak vscode fonts" ;;
      esac
      ;;

    # ── Check dependencies ──
    check)
      printf "\n\033[1m\033[0;36m  Dependency Check\033[0m\n\n"
      for cmd in chezmoi brew git zsh kitty code mise cargo uv flatpak hyprctl waybar rofi \
        wallust hyprsession lazygit btop fastfetch grim slurp wl-copy swappy grimblast \
        jq curl wget rg fd bat lsd age restic notify-send; do
        if command -v "$cmd" &>/dev/null; then
          printf "  \033[0;32m✓\033[0m  %-16s %s\n" "$cmd" "$(command -v $cmd)"
        else
          printf "  \033[0;31m✗\033[0m  %-16s \033[0;31mnot found\033[0m\n" "$cmd"
        fi
      done
      printf "\n\033[1m  Zsh plugins:\033[0m\n"
      for plugin in zsh-autosuggestions zsh-syntax-highlighting; do
        if [ -d "$DOTS_ZSH_CUSTOM/plugins/$plugin" ]; then
          printf "  \033[0;32m✓\033[0m  %s\n" "$plugin"
        else
          printf "  \033[0;31m✗\033[0m  %s \033[0;31mnot found\033[0m\n" "$plugin"
        fi
      done
      if [ -d "$DOTS_ZSH_CUSTOM/themes/powerlevel10k" ]; then
        printf "  \033[0;32m✓\033[0m  powerlevel10k\n"
      else
        printf "  \033[0;31m✗\033[0m  powerlevel10k \033[0;31mnot found\033[0m\n"
      fi
      printf "\n\033[1m  Fonts:\033[0m\n"
      for font_dir in "$HOME"/.local/share/fonts/*/; do
        [ -d "$font_dir" ] && printf "  \033[0;32m✓\033[0m  %s\n" "$(basename $font_dir)"
      done
      printf "\n"
      ;;

    # ── Init (full first-time setup) ──
    init)
      echo "==> Full dotfiles init"
      dots install all
      chezmoi apply -v
      printf "\033[0;32m✓ Init complete — restart your shell\033[0m\n"
      ;;

    # ── Help ──
    help|--help|-h)
      printf "\n\033[1m\033[0;36m  dots\033[0m — dotfiles management\n\n"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots init"           "Full first-time setup (install all + apply)"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots apply"          "Apply chezmoi source → home"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots sync"           "Re-add changed files, show status"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots diff"           "Preview what chezmoi would change"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots status"         "Show chezmoi + git status"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots update"         "Git pull + chezmoi apply"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots doctor"         "Run chezmoi doctor"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots cd"             "cd to chezmoi source dir"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots edit <file>"    "Edit a managed file"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots check"          "Verify all dependencies installed"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots install"        "Run all install targets"
      printf "  \033[0;32m%-22s\033[0m %s\n" "dots install <name>" "Install: omz brew apt mise cargo uv flatpak vscode fonts"
      printf "\n"
      ;;

    *)
      echo "Unknown command: $cmd"
      dots help
      ;;
  esac
}

# ===========================
# ENV VARIABLES
# ===========================
export EDITOR='hx'
export VISUAL='hx'
export GIT_PAGER='delta'

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

eval "$(zoxide init zsh)"
