{{- if lookPath "hyprland" }}
# Auto-start Hyprland on TTY1
if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
  exec start-hyprland
fi
{{- end }}

# ===========================
# OH-MY-ZSH CONFIG
# ===========================
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
  git
  docker
  sudo
  copypath
  copyfile
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# ===========================
# PATH & ENVIRONMENT
# ===========================
{{- if eq .chezmoi.os "linux" }}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{- else if eq .chezmoi.os "darwin" }}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- end }}
eval "$(mise activate zsh)"
export PATH="$HOME/.local/bin:$PATH"
{{- if .use1Password }}
export SSH_AUTH_SOCK=~/.1password/agent.sock
{{- end }}

# fzf integration
source <(fzf --zsh)

# ===========================
# MODERN CLI TOOL ALIASES
# ===========================
# eza (better ls)
alias ls='eza --color=always --icons=always'
alias ll='eza -la --color=always --icons=always --git'
alias lt='eza --tree --level=2 --icons=always'
alias la='eza -a --color=always --icons=always'

# bat (better cat)
alias cat='bat --paging=never'
alias catp='bat'

# fd (better find)
alias find='fd'

# ripgrep (better grep)
alias grep='rg'

# zoxide (better cd)
alias cd='z'

# btop (better htop)
alias top='btop'
alias htop='btop'

# ===========================
# FZF + MODERN TOOLS INTEGRATION
# ===========================
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --follow --exclude .git'

show_file_or_dir_preview="if [ -d {} ]; then eza --tree --color=always {} | head -200; else bat -n --color=always --line-range :500 {}; fi"
export FZF_CTRL_T_OPTS="--preview '$show_file_or_dir_preview'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always {} | head -200'"

# ===========================
# ALIASES: Package Managers
# ===========================
alias update-all='brew upgrade && flatpak update -y && sudo apt update && sudo apt upgrade -y'
alias b='bun'
alias bi='bun install'
alias br='bun run'
alias brd='bun run dev'
alias brb='bun run build'
alias brt='bun run test'
alias bx='bunx'

# ===========================
# ALIASES: Python (uv)
# ===========================
alias py='python3'
alias pip='uv pip'
alias pip3='uv pip'
alias uvinit='~/scripts/uv-init-pinned.sh'

# ===========================
# ALIASES: Git
# ===========================
alias g='git'
alias gs='git status'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit -m'
alias gp='git push'
alias gpl='git pull'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch'
alias gd='git diff'
alias gl='git log --graph --oneline --all --pretty=format:"%C(auto)%h %C(auto)%d %C(auto)%s %C(blue)(%cd %ae)" --date=format:"%I:%M %p %a %b %d"'
alias gpr='git fetch --prune && git branch -vv | grep :'
alias lg='lazygit'

# ===========================
# ALIASES: Docker
# ===========================
alias d='docker'
alias dc='docker compose'
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcl='docker compose logs -f'
alias dps='docker ps'
alias dpsa='docker ps -a'
alias dprune='docker system prune -af'

# ===========================
# CLAUDE CODE
# ===========================
alias cc='claude'
alias ccr='claude --resume'
alias ccc='claude --continue'
alias claude-init='~/scripts/init-claude-project.sh'
alias cidx="~/scripts/cidx.sh"

# ===========================
# MISE ALIASES
# ===========================
alias mr='mise run'
alias mu='mise use'
alias mi='mise install'
alias ml='mise list'
alias mx='mise exec'

# Quick language switching
alias usebun='mise use bun@latest'
alias usenode='mise use node@22'
alias usepy='mise use python@3.13'

# ===========================
# ALIASES: Navigation
# ===========================
alias ..='z ..'
alias ...='z ../..'
alias ....='z ../../..'
alias ~='z ~'

# ===========================
# ALIASES: Utilities
# ===========================
alias c='clear'
alias h='history'
alias hg='history | rg'
alias ports='netstat -tulanp'
alias myip='curl -s ifconfig.me'
alias weather='curl wttr.in'
alias sizeof='du -sh'
alias storage='ncdu'
alias wifi='~/scripts/rofi-wifi-menu/rofi-wifi-menu.sh'
alias about='neofetch'
alias reload-waybar='killall waybar && waybar &'
alias neu-vpn='sudo -E gpclient connect --browser default vpn.northeastern.edu'

# ===========================
# ALIASES: Quick Edits
# ===========================
alias zshrc='hx ~/.zshrc'
alias reload='source ~/.zshrc'

# ===========================
# FUNCTIONS
# ===========================
mkcd() { mkdir -p "$1" && z "$1"; }
fe() { fzf --preview 'bat --color=always {}' | xargs -r hx; }
se() { rg --line-number "$1" | fzf | cut -d: -f1 | xargs -r hx; }

# ===========================
# ENV VARIABLES
# ===========================
export EDITOR='hx'
export VISUAL='hx'
export GIT_PAGER='delta'

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

eval "$(zoxide init zsh)"
